# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection string (PgBouncer) — use for app queries
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct connection — use for Prisma migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Application ─────────────────────────────────────────────────────────────
# 32-char random string for HMAC API key signing — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SALT="your-32-char-random-string-here"

NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ─── External SKU Catalog (final-sku.vercel.app) ─────────────────────────────
# Base URL of the external SKU catalog app (defaults to https://final-sku.vercel.app)
FINAL_SKU_API_URL="https://final-sku.vercel.app"
# API key fallback — optional if configured via Admin → SKU Catalog → Connect
FINAL_SKU_API_KEY="oap_..."
