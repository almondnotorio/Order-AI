generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Reflectivity {
  NONE
  EG
  HIP
  DG3
}

enum Sides {
  SINGLE
  DOUBLE
}

enum Material {
  ALUMINUM
  STEEL
  PLASTIC
}

enum OrderStatus {
  PENDING
  PROCESSING
  REVIEW
  APPROVED
  REJECTED
  FULFILLED
}

enum AIStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum DeliveryType {
  STANDARD
  RUSH
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── SKU Catalog ──────────────────────────────────────────────────────────────

model SKU {
  id           String       @id @default(cuid())
  sku_code     String       @unique
  description  String
  width_in     Float
  height_in    Float
  thickness    String
  reflectivity Reflectivity
  sides        Sides
  material     Material
  active       Boolean      @default(true)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  orders Order[]

  @@index([material, reflectivity, sides])
}

// ─── Users (mirrored from Clerk) ──────────────────────────────────────────────

model User {
  id         String   @id
  email      String   @unique
  name       String?
  role       Role     @default(CUSTOMER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  orders   Order[]
  api_keys ApiKey[]
}

// ─── API Keys (external callers) ──────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  key_hash   String    @unique
  label      String
  user_id    String
  last_used  DateTime?
  revoked    Boolean   @default(false)
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── System Settings (key-value store for runtime configuration) ──────────────

model SystemSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id      String @id @default(cuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  raw_input String

  ai_status           AIStatus    @default(PENDING)
  parsed_width        Float?
  parsed_height       Float?
  parsed_thickness    String?
  parsed_reflectivity String?
  parsed_sides        String?
  parsed_material     String?
  parsed_delivery     DeliveryType?
  parsed_quantity     Int?

  confidence_score Float?
  matched_sku_id   String?
  matched_sku      SKU?    @relation(fields: [matched_sku_id], references: [id])
  ai_notes         String?
  flags            Json?
  ai_raw_response  Json?

  status        OrderStatus  @default(PENDING)
  delivery_type DeliveryType @default(STANDARD)
  admin_remark  String?

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  processed_at DateTime?

  @@index([user_id])
  @@index([status])
  @@index([ai_status])
  @@index([created_at])
}
